# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored and never committed.
# Roboflow API key: https://app.roboflow.com/settings/api

ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_WORKSPACE_NAME=video-analizer

# Optional — defaults to "custom-workflow" in the API route.
# ROBOFLOW_WORKFLOW_ID=custom-workflow
